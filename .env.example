# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini


# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter Configuration
OPENROUTER_API_KEY=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
OCR_LLM_PROVIDER=openrouter
OCR_LLM_MODEL_NAME=amazon/nova-lite-v1

# Application Settings
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:3010
FRONTEND_URL=http://localhost:5173

VERBOSE=true

# Frontend API Configuration
VITE_API_BASE_URL=http://localhost:8010

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Recall Configuration
RECALL_START_HOUR=9
RECALL_END_HOUR=22
RECALL_INTERVAL_MINUTES=60

# Vocabulary Learning Configuration
WORDS_PER_DAY=5
COOLDOWN_DAYS=7

# Database Configuration
# Use postgresql+asyncpg:// for the application (async)
# and postgresql+psycopg2:// for Alembic (sync) - handled in code
POSTGRES_USER=runestone
POSTGRES_PASSWORD=runestone
POSTGRES_DB=runestone
DATABASE_URL=postgresql+asyncpg://runestone:runestone@localhost:5432/runestone

# JWT Configuration
# Generate a strong secret key using a command like: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-and-long-random-string-here

# Agents
AGENT_PERSONA=default

# Teacher Agent Configuration
TEACHER_PROVIDER=openrouter
TEACHER_MODEL=my_model
TEACHER_REASONING_LEVEL=none
TEACHER_TEMPERATURE=1.0

# Coordinator Agent Configuration
COORDINATOR_PROVIDER=openrouter
COORDINATOR_MODEL=my_model
COORDINATOR_REASONING_LEVEL=minimal
COORDINATOR_TEMPERATURE=0.0

# WordKeeper Agent Configuration
WORD_KEEPER_PROVIDER=openrouter
WORD_KEEPER_MODEL=my_model
WORD_KEEPER_REASONING_LEVEL=none
WORD_KEEPER_TEMPERATURE=0.0

# MemoryKeeper Agent Configuration
MEMORY_KEEPER_PROVIDER=openrouter
MEMORY_KEEPER_MODEL=my_model
MEMORY_KEEPER_REASONING_LEVEL=none
MEMORY_KEEPER_TEMPERATURE=0.0

# News Agent Configuration
NEWS_AGENT_PROVIDER=openrouter
NEWS_AGENT_MODEL=my_model
NEWS_AGENT_REASONING_LEVEL=none
NEWS_AGENT_TEMPERATURE=0.0

# TTS (Text-to-Speech) Configuration
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=onyx
