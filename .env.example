# LLM Provider Configuration
LLM_PROVIDER=openai
# Optional shared model override. Leave unset to use provider defaults.
# LLM_MODEL_NAME=gpt-4o-mini


# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Comma-separated provider slugs to avoid via OpenRouter routing, e.g. "bad-provider".
OPENROUTER_DISALLOWED_PROVIDERS=
OCR_LLM_PROVIDER=openrouter
OCR_LLM_MODEL_NAME=amazon/nova-lite-v1

# Hugging Face Configuration
# Hugging Face Hub token to speed up downloads and avoid rate limits
HF_TOKEN=your_huggingface_token_here

# Application Settings
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:3010
FRONTEND_URL=http://localhost:5173

VERBOSE=true

# Frontend API Configuration
VITE_API_BASE_URL=http://localhost:8010

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Recall Configuration
RECALL_START_HOUR=9
RECALL_END_HOUR=22
RECALL_INTERVAL_MINUTES=60

# Vocabulary Learning Configuration
WORDS_PER_DAY=5
COOLDOWN_DAYS=7

# Database Configuration
# Use postgresql+asyncpg:// for the application (async)
# and postgresql+psycopg2:// for Alembic (sync) - handled in code
POSTGRES_USER=runestone
POSTGRES_PASSWORD=runestone
POSTGRES_DB=runestone
DATABASE_URL=postgresql+asyncpg://runestone:runestone@localhost:5432/runestone
# Compose overrides DATABASE_URL to use the postgres service hostname.
# Tune these down/up for the deployment host. Total possible connections per
# backend process are DATABASE_POOL_SIZE + DATABASE_MAX_OVERFLOW.
DATABASE_POOL_SIZE=8
DATABASE_MAX_OVERFLOW=8
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true
STARTUP_DB_CHECK=true
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=384MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_CHECKPOINT_TIMEOUT=15min
POSTGRES_MAX_WAL_SIZE=512MB
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=7

# JWT Configuration
# Generate a strong secret key using a command like: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-and-long-random-string-here

# Agents
AGENT_PERSONA=default

# Teacher Agent Configuration
TEACHER_PROVIDER=openrouter
TEACHER_MODEL=my_model
TEACHER_REASONING_LEVEL=none
TEACHER_TEMPERATURE=1.0
# TEACHER_LLM_TIMEOUT_SECONDS=10.0
# TEACHER_MAX_RETRIES=1

# Optional Teacher Backup Agent Configuration (set the model to enable)
# TEACHER_BACKUP_PROVIDER=gemini
# TEACHER_BACKUP_MODEL=gemini-2.5-flash
# TEACHER_BACKUP_TEMPERATURE=1.0
# TEACHER_BACKUP_REASONING_LEVEL=minimal
# TEACHER_BACKUP_LLM_TIMEOUT_SECONDS=5.0
# TEACHER_BACKUP_MAX_RETRIES=1

# Coordinator Agent Configuration
COORDINATOR_PROVIDER=openrouter
COORDINATOR_MODEL=my_model
COORDINATOR_REASONING_LEVEL=minimal
COORDINATOR_TEMPERATURE=0.0
# COORDINATOR_LLM_TIMEOUT_SECONDS=3.0
# COORDINATOR_MAX_RETRIES=3

# WordKeeper Agent Configuration
WORD_KEEPER_PROVIDER=openrouter
WORD_KEEPER_MODEL=my_model
WORD_KEEPER_REASONING_LEVEL=none
WORD_KEEPER_TEMPERATURE=0.0
# WORD_KEEPER_LLM_TIMEOUT_SECONDS=15.0
# WORD_KEEPER_MAX_RETRIES=3

# MemoryKeeper Agent Configuration
MEMORY_KEEPER_PROVIDER=openrouter
MEMORY_KEEPER_MODEL=my_model
MEMORY_KEEPER_REASONING_LEVEL=none
MEMORY_KEEPER_TEMPERATURE=0.0
# Per-agent timeout and retry budgets for the two memory-keeper variants:
# LEARNING_MEMORY_KEEPER_LLM_TIMEOUT_SECONDS=15.0
# LEARNING_MEMORY_KEEPER_MAX_RETRIES=3
# PERSONAL_MEMORY_KEEPER_LLM_TIMEOUT_SECONDS=8.0
# PERSONAL_MEMORY_KEEPER_MAX_RETRIES=2

# MemoryMaintainer Agent Configuration
MEMORY_MAINTAINER_PROVIDER=openrouter
MEMORY_MAINTAINER_MODEL=my_model
MEMORY_MAINTAINER_REASONING_LEVEL=none
MEMORY_MAINTAINER_TEMPERATURE=0.0
# MEMORY_MAINTAINER_LLM_TIMEOUT_SECONDS=30.0
# MEMORY_MAINTAINER_MAX_RETRIES=3

# News Agent Configuration
NEWS_AGENT_PROVIDER=openrouter
NEWS_AGENT_MODEL=my_model
NEWS_AGENT_REASONING_LEVEL=none
NEWS_AGENT_TEMPERATURE=0.0
# NEWS_AGENT_LLM_TIMEOUT_SECONDS=10.0
# NEWS_AGENT_MAX_RETRIES=3

# Memory / Retention Configuration
MEMORY_MASTERED_CLEANUP_DAYS=3
# MEMORY_MAINTENANCE_TIMEOUT_SECONDS=240.0

# Voice Transcription Configuration
VOICE_TRANSCRIPTION_PROVIDER=openai
# Use whisper-1 for OpenAI STT or scribe_v2 for ElevenLabs STT.
VOICE_TRANSCRIPTION_MODEL=whisper-1
VOICE_ENHANCEMENT_MODEL=gpt-4o-mini
VOICE_MAX_DURATION_SECONDS=300
VOICE_MAX_FILE_SIZE_MB=25

# TTS (Text-to-Speech) Configuration
TTS_PROVIDER=openai
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=onyx

# ElevenLabs Voice Configuration (required when *_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_TTS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TTS_STABILITY=0.5
ELEVENLABS_TTS_SIMILARITY_BOOST=0.75
ELEVENLABS_TTS_STYLE=0.0
ELEVENLABS_TTS_USE_SPEAKER_BOOST=true
